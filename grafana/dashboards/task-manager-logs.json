{
  "title": "Task Manager - Application Logs",
  "uid": "task-manager-logs",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "API Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "{service=\"api\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 10
      }
    },
    {
      "id": 2,
      "title": "Errors",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "{service=\"api\"} |= \"ERROR\"",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 3,
      "title": "Exceptions",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "{service=\"api\"} |~ \"Exception|ExceptionHandler\"",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 4,
      "title": "Authentication Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "{service=\"api\"} |~ \"JWT|Unauthorized|Authentication|Login\"",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 8
      }
    }
  ]
}